# Shared
APP_ENV=development
PUBLIC_APP_NAME=SpeakAble

# AWS Cognito
NEXT_PUBLIC_AWS_REGION=
NEXT_PUBLIC_AWS_COGNITO_USER_POOL_ID=
NEXT_PUBLIC_AWS_COGNITO_USER_POOL_CLIENT_ID=
EXPO_PUBLIC_AWS_REGION=
EXPO_PUBLIC_AWS_COGNITO_USER_POOL_ID=
EXPO_PUBLIC_AWS_COGNITO_USER_POOL_CLIENT_ID=
AWS_REGION=
AWS_COGNITO_USER_POOL_ID=
AWS_COGNITO_USER_POOL_CLIENT_ID=

# MERN API
NEXT_PUBLIC_API_URL=http://localhost:8000
EXPO_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_ALLOW_LOCAL_DEMO_FALLBACK=true
EXPO_PUBLIC_ALLOW_LOCAL_DEMO_FALLBACK=false
NEXT_PUBLIC_ENABLE_SUBMISSION_DEMO=false
EXPO_PUBLIC_ENABLE_SUBMISSION_DEMO=false
CORS_ORIGINS=http://localhost:3000,http://localhost:8081
AUTH_REQUIRED=false
AUTH_ISSUER=
AUTH_AUDIENCE=
DATA_STORE=memory
MONGODB_URI=mongodb://localhost:27017/speakable
SEED_USER_ID=local-demo-user
VOICE_ROLE_PLAY_ENABLED=false
EXTERNAL_SHARING_ENABLED=false

# Optional future model provider
COACH_MODEL_PROVIDER=deterministic
COACH_MODEL_NAME=
COACH_MODEL_API_KEY=
